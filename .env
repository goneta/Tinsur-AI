APP_NAME=Insurance SaaS Platform
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# DATABASE_URL=postgresql://postgres:password@localhost/insurance_saas
DATABASE_URL=sqlite:///./insurance.db

SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Redis
REDIS_URL=redis://localhost:6379/0

# MongoDB
MONGODB_URL=mongodb://localhost:27017/insurance_saas_logs
MONGODB_DB_NAME=insurance_saas_logs

# Agent Configuration
OPENAI_API_KEY=sk-placeholder
GEMINI_API_KEY=your-gemini-key

# Port Configuration
PORT=8000
